{
    "$schema": "https://playground.wordpress.net/blueprint-schema.json",
    "meta": {
        "title": "WebberZone Contextual Related Posts — GitHub Version",
        "description": "Try WebberZone Contextual Related Posts from GitHub master branch with pre-imported posts.",
        "author": "webberzone"
    },
    "landingPage": "/wp-admin/options-general.php?page=crp_options_page",
    "preferredVersions": {
        "php": "8.3",
        "wp": "latest"
    },
    "features": {
        "networking": true
    },
    "login": true,
    "steps": [
        {
            "step": "installPlugin",
            "pluginZipFile": {
                "resource": "url",
                "url": "https://github.com/WebberZone/contextual-related-posts/archive/refs/heads/master.zip"
            },
            "options": {
                "activate": true
            }
        },
        {
            "step": "importWxr",
            "file": {
                "resource": "url",
                "url": "https://raw.githubusercontent.com/WebberZone/contextual-related-posts/master/.playground/demo-content.xml"
            }
        }
    ]
}
